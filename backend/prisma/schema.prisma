generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  queries      RagQuery[]
}

model RagQuery {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}